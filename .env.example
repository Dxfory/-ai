UPLOAD_DIR=./uploads

# AI 白描稿生成。不要把真实 key 提交到 Git。
BAIMIAO_API_BASE=https://lingsuan.top
BAIMIAO_API_KEY=replace-with-your-api-key
BAIMIAO_IMAGE_MODEL=gpt-image-1
BAIMIAO_IMAGE_SIZE=auto
BAIMIAO_USE_STRUCTURE_GUIDE=true
BAIMIAO_PRESERVE_SOURCE_ASPECT=true
BAIMIAO_CLEAN_OUTPUT=true
BAIMIAO_CLIP_TO_BORDER=true
BAIMIAO_REPAIR_LINES=true
BAIMIAO_LINE_REPAIR_MAX_GAP=2
BAIMIAO_SMOOTH_JUNCTIONS=true
BAIMIAO_MAX_JUNCTION_THICKNESS=3

# 教材页面视觉/OCR 抽取。输出结果默认只保留本地，不提交 Git。
TEACHING_VISION_API_BASE=https://lingsuan.top
TEACHING_VISION_API_KEY=replace-with-your-api-key
TEACHING_VISION_MODEL=gpt-5.5
TEACHING_VISION_WIRE_API=responses

# Fenran 分染教学渲染。默认使用 OpenAI-compatible image edit 接口。
FENRAN_API_BASE=https://api.openai.com/v1
FENRAN_API_KEY=replace-with-your-api-key
FENRAN_IMAGE_MODEL=gpt-image-2
FENRAN_IMAGE_SIZE=auto
FENRAN_IMAGE_TIMEOUT_SECONDS=240

# Fenran generation
FENRAN_MAX_ATTEMPTS=3
FENRAN_MIN_VALIDATION_SCORE=0.80
FENRAN_FAIL_CLOSED=true
FENRAN_ALLOW_SINGLE_REFERENCE_FALLBACK=false
FENRAN_ENABLE_CACHE=true

# Canonical coordinate
FENRAN_PRESERVE_CANONICAL_COORDINATES=true
FENRAN_API_MAX_IMAGE_SIDE=1536

# Validation
FENRAN_MIN_SUBJECT_BBOX_IOU=0.90
FENRAN_MAX_SUBJECT_CENTER_SHIFT_RATIO=0.02
FENRAN_MAX_SUBJECT_SIZE_CHANGE_RATIO=0.04
FENRAN_MIN_SUBJECT_COVERAGE=0.92
FENRAN_MAX_OUTSIDE_SUBJECT_CHANGE_RATIO=0.01
FENRAN_MIN_LINE_RETENTION_RATIO=0.35
